<!DOCTYPE html>
<html lang="en">

<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1" />
	<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
	<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
	<title><%= title %> - Web Truyện</title>
</head>

<body>
	<div class="container">
		<!-- Menu ngang -->
		<%- include('navbar') %>
		
		<!-- Nội dung chính -->
		<div class="card mt-3">
			<div class="card-header"><%= title %></div>
			<div class="card-body table-responsive">
				<a href="/chuong/them/<%= truyenId %>" class="btn btn-primary mb-2"><i class="bi bi-plus-lg"></i> Thêm chương</a>
				<table class="table table-bordered table-hover table-sm mb-0">
					<thead>
						<tr>
							<th width="5%">#</th>
							<th width="15%">Số chương</th>
							<th width="15%">Tiêu đề</th>
							<th width="40%">Nội dung</th>
							<th width="10%">Ngày đăng</th>
							<th width="5%" title="Tình trạng kiểm duyệt?">Duyệt</th>
							<th width="5%">Sửa</th>
							<th width="5%">Xóa</th>
						</tr>
					</thead>
					<tbody>
						<% var stt = 1; %>
						<% chuong.forEach(ch => { %>
							<tr>
								<td class="align-middle"><%= stt++ %></td>
								<td class="align-middle small"><%= ch.SoChuong %></td>
								<td class="align-middle small"><%= ch.TieuDe %></td>
								<td class="align-middle small">
									<span class="short-text">
										<%= ch.NoiDung.length > 100 
											? ch.NoiDung.substring(0, 100) + '...' 
											: ch.NoiDung %>
									</span>

									<span class="full-text d-none">
										<%= ch.NoiDung %>
									</span>

									<% if (ch.NoiDung.length > 100) { %>
										<br>
										<a href="javascript:void(0);" class="toggle-btn text-primary">Xem thêm</a>
									<% } %>
								</td>
								<td class="align-middle small"><%= new Date(ch.NgayDang.toISOString()).toLocaleString("vi-VN") %></td>
								<td class="align-middle text-center">
									<% if(ch.KiemDuyet == 1) { %>
										<a href="/chuong/duyet/<%= ch._id %>"><i class="bi bi-check-circle"></i></a>
									<% } else { %>
										<a href="/chuong/duyet/<%= ch._id %>"><i class="bi bi-x-circle text-danger"></i></a>
									<% } %>
								</td>
								<td class="align-middle text-center">
									<a href="/chuong/sua/<%= ch._id %>"><i class="bi bi-pencil-square"></i></a>
								</td>
								<td class="align-middle text-center">
									<a href="/chuong/xoa/<%= ch._id %>" onclick="return confirm('Bạn có muốn xóa chương <%= ch.TieuDe %> không?');">
										<i class="bi bi-trash text-danger"></i>
									</a>
								</td>
							</tr>
						<% }); %>
					</tbody>
				</table>
			</div>
		</div>
		
		<!-- Footer -->
		<%- include('footer') %>
	</div>
	
	<%- include('javascript') %>
	
	<script>
		document.addEventListener("DOMContentLoaded", function () {
			document.querySelectorAll(".toggle-btn").forEach(btn => {
				btn.addEventListener("click", function () {
					const td = this.closest("td");
					const shortText = td.querySelector(".short-text");
					const fullText = td.querySelector(".full-text");

					if (fullText.classList.contains("d-none")) {
						fullText.classList.remove("d-none");
						shortText.classList.add("d-none");
						this.innerText = "Thu gọn";
					} else {
						fullText.classList.add("d-none");
						shortText.classList.remove("d-none");
						this.innerText = "Xem thêm";
					}
				});
			});
		});
	</script>
</body>

</html>