<!DOCTYPE html>
<html lang="en">
<head>
	<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
	<meta charset="utf-8" />
	<meta http-equiv="X-UA-Compatible" content="IE=edge" />
	<meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
	<meta name="description" content="Trang web đọc truyện online." />
	<meta name="author" content="Lê Nhựt Hào - Nguyễn Chí Thanh" />
	<title><%= title %> - Web đọc truyện</title>
	<link href="./css/app.css" rel="stylesheet" />
</head>
<body>
	<header>
		<nav class="navbar navbar-expand-md navbar-dark shadow"
			style="background: linear-gradient(90deg, #0d6efd, #0dcaf0); overflow:visible;">
			<div class="container">

				<button class="navbar-toggler order-2 order-md-1" type="button"
					data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
					<span class="navbar-toggler-icon"></span>
				</button>

				<!-- LEFT -->
				<div class="collapse navbar-collapse order-3 order-md-2" id="navbar-left">
					<ul class="navbar-nav me-auto fw-semibold">
						<li class="nav-item dropdown active">
							<a class="nav-link dropdown-toggle text-white"
							href="#" id="chuyenmuc"
							data-bs-toggle="dropdown"
							style="transition:0.2s;"
							onmouseover="this.style.color='#ffd700'"
							onmouseout="this.style.color='white'">
								<i class="bi bi-list"></i> Chuyên mục
							</a>

							<div class="dropdown-menu shadow border-0">
								<% if(typeof chuyenmuc !== "undefined") { chuyenmuc.forEach(tl => { %>
									<a class="dropdown-item"
									href="/truyen/theloai/<%= tl._id %>"
									style="transition:0.2s;"
									onmouseover="this.style.background='#f1f1f1'">
										<%= tl.TenTheLoai %>
									</a>
								<% }); } %>
							</div>
						</li>
					</ul>
				</div>


				<!-- LOGO -->
				<a class="navbar-brand mx-auto order-1 order-md-3 fw-bold text-white"
					href="/"
					style="font-size: 22px; letter-spacing:1px; text-transform:none;">
						<i class="bi bi-book-half"></i> iTruyens
				</a>

				<!-- RIGHT -->
				<div class="collapse navbar-collapse order-4 order-md-4" id="navbar-right">
					<ul class="navbar-nav ms-auto fw-semibold">

						<% if(typeof session === "undefined" || !session.MaNguoiDung) { %>
							<li class="nav-item">
								<a class="nav-link text-white"
								href="/dangky"
								onmouseover="this.style.color='#ffd700'"
								onmouseout="this.style.color='white'">
									<i class="bi bi-person-plus"></i> Đăng ký
								</a>
							</li>

							<li class="nav-item">
								<a class="nav-link text-white"
								href="/dangnhap"
								onmouseover="this.style.color='#ffd700'"
								onmouseout="this.style.color='white'">
									<i class="bi bi-box-arrow-in-right"></i> Đăng nhập
								</a>
							</li>

						<% } else { %>

							<li class="nav-item position-relative">

								<a class="nav-link text-white d-flex align-items-center"
								href="#"
								id="userMenu"
								style="transition:0.2s;"
								onmouseover="this.style.color='#ffd700'"
								onmouseout="this.style.color='white'">

									<img src="<%= session.HinhAnh || '/images/noimage.png' %>"
										style="width:32px;height:32px;border-radius:50%;object-fit:cover;margin-right:8px;border:2px solid white;">

									<%= session.HoVaTen %>
								</a>

								<div class="dropdown-menu shadow border-0"
									id="userDropdown"
									style="position:absolute; right:0; top:100%; display:block; visibility:hidden; opacity:0; transition:0.2s;">

									<a class="dropdown-item" href="/truyen/them">Đăng truyện</a>
									<a class="dropdown-item" href="/truyen/cuatoi">Truyện của tôi</a>

									<hr class="dropdown-divider">

									<% if(session && session.QuyenHan === 'admin') { %>
										<a class="dropdown-item" href="/admin">Quản lý trang web</a>
									<% } else { %>
										<a class="dropdown-item" href="/taikhoan/profile">Hồ sơ cá nhân</a>
									<% } %>

									<a class="dropdown-item text-danger" href="/dangxuat">Đăng xuất</a>
								</div>

							</li>

						<% } %>
					</ul>

					<!-- SEARCH -->
					<form class="d-flex ms-3" role="search" action="/timkiem" method="post">
						<input name="tukhoa"
							class="form-control me-2"
							type="text"
							placeholder="Tìm kiếm..."
							value="<%= tukhoa || '' %>"
							autocomplete="off"
							required
							style="border-radius: 20px;">

						<button class="btn btn-primary rounded-pill px-3" type="submit">
							<i class="bi bi-search" style="color:white; font-size:16px;"></i>
						</button>
					</form>

				</div>
			</div>
		</nav>
	</header>
	<main class="main pt-4">
		<div class="container">
			<div class="row">
				<div class="col-md-9">
					<% if(typeof truyenDeCu !== "undefined") { %>
						<div id="truyenCarousel" class="carousel slide mb-4" data-bs-ride="carousel" data-bs-interval="3000">

							<div class="carousel-inner shadow" style="border-radius:20px; overflow:hidden;">

								<% truyenDeCu.forEach((tr, index) => { %>
									<div class="carousel-item <%= index === 0 ? 'active' : '' %>">

										<div class="row g-0" style="height:300px; background:#111; color:white; border-radius:15px;">

											<!-- ẢNH -->
											<div class="col-md-5 d-flex justify-content-center align-items-center"
												style="background:black; height:100%; padding:15px;">

												<img src="<%- tr.HinhAnh %>"
													style="max-width:100%; max-height:100%; object-fit:contain; border-radius:10px;"
													onerror="this.src='/images/noimage.png'">
											</div>

											<!-- NỘI DUNG -->
											<div class="col-md-7 d-flex flex-column justify-content-center p-3">

												<h4 class="fw-bold" style="font-size:22px;">
													<%= tr.TenTruyen %>
												</h4>

												<p style="opacity:0.9; font-size:15px;">
													<%= tr.TomTat.length > 180 
														? tr.TomTat.substring(0,180) + '...' 
														: tr.TomTat %>
												</p>

												<a href="/truyen/chitiet/<%= tr._id %>" 
												class="btn btn-primary mt-2" 
												style="width:160px; border-radius:20px;">
													Đọc ngay
												</a>

											</div>

										</div>

									</div>
								<% }); %>

							</div>

							<!-- Nút điều hướng -->
							<button class="carousel-control-prev" type="button" data-bs-target="#truyenCarousel" data-bs-slide="prev">
								<span class="carousel-control-prev-icon"></span>
							</button>

							<button class="carousel-control-next" type="button" data-bs-target="#truyenCarousel" data-bs-slide="next">
								<span class="carousel-control-next-icon"></span>
							</button>

						</div>
						<% } %>
					<div class="row">
						<% if(typeof truyen !== "undefined") { %>
							<% truyen.forEach(tr => { %>

								<div class="col-md-6 col-lg-4 mb-4">
									<a href="/truyen/chitiet/<%= tr._id %>" style="text-decoration:none; color:inherit;">
										<div class="card h-100 border-0 shadow-sm"
											style="border-radius:15px; overflow:hidden; transition:0.3s;"
											onmouseover="this.style.transform='translateY(-6px)'; this.style.boxShadow='0 12px 25px rgba(0,0,0,0.2)'"
											onmouseout="this.style.transform=''; this.style.boxShadow=''">

											<!-- ẢNH -->
											<div style="width:100%; aspect-ratio:3/4; overflow:hidden; border-radius:10px;">
												<img src="<%- (tr.HinhAnh && tr.HinhAnh.trim()) ? tr.HinhAnh : '/images/noimage.png' %>"
													style="width:100%; height:100%; object-fit:cover;">
											</div>

											<!-- NỘI DUNG -->
											<div class="card-body d-flex flex-column">

												<h5 class="fw-bold" style="font-size:16px; min-height:45px;">
													<%= tr.TenTruyen %>
												</h5>

												<div class="mb-2 text-muted" style="font-size:13px;">
													<i class="bi bi-clock"></i> <%= formatTime(tr.NgayDang) %>
												</div>

												<div class="mb-2">
													<span class="badge bg-primary">
														<%= tr.TheLoai?.TenTheLoai %>
													</span>
												</div>

												<p class="text-muted" style="font-size:14px; flex-grow:1;">
													<%= tr.TomTat.length > 100 
														? tr.TomTat.substring(0,100) + '...' 
														: tr.TomTat %>
												</p>

												<a href="/truyen/chitiet/<%= tr._id %>"
													class="btn btn-outline-primary w-100 mt-2"
													style="border-radius:20px;">
													Xem chi tiết
												</a>

											</div>
										</div>
									</a>
								</div>

							<% }); %>
						<% } %>
					</div>
					<nav>
						<ul class="pagination justify-content-center">
							<li class="page-item disabled">
								<a class="page-link" href="#" tabindex="-1" aria-disabled="true">Về trước</a>
							</li>
							<li class="page-item"><a class="page-link" href="#">1</a></li>
							<li class="page-item"><a class="page-link" href="#">2</a></li>
							<li class="page-item"><a class="page-link" href="#">3</a></li>
							<li class="page-item">
								<a class="page-link" href="#">Về sau</a>
							</li>
						</ul>
					</nav>
				</div>
				<div class="col-md-3 ms-auto">
					<aside class="sidebar">
						<div class="card mb-4">
							<div class="card-body">
								<h4 class="card-title">Giới thiệu</h4>
								<p class="card-text">Đọc truyện trên trang web này giúp bạn cực kỳ thư giản. Đừng quên chia sẻ trang này cho toàn bộ vũ trụ biết nhé. Mến yêu.</p>
							</div>
						</div>
					</aside>
					<aside class="sidebar sidebar-sticky">
						<div class="card mb-4">
							<div class="card-body">
								<h4 class="card-title">Thẻ</h4>
								<% if(typeof chuyenmuc !== "undefined") { chuyenmuc.forEach(tl => { %>
									<a class="btn btn-light btn-sm mb-1" href="/truyen/theloai/<%= tl._id %>"><%= tl.TenTheLoai %></a>
								<% }); } %>
							</div>
						</div>
						<div class="card mb-4">
							<div class="card-body">
								<h4 class="card-title">Xem nhiều nhất</h4>
								<% if(typeof xemnhieunhat !== "undefined") { xemnhieunhat.forEach(tr => { %>
									<a href="/truyen/chitiet/<%= tr._id %>" class="d-inline-block mt-3">
										<h4 class="h6"><%= tr.TenTruyen %></h4>
										<img class="card-img" src="<%- (tr.HinhAnh && tr.HinhAnh.trim()) ? tr.HinhAnh : '/images/noimage.png' %>" onerror="this.onerror=null;this.src='/images/noimage.png';" alt="" />
									</a>
									<span><%= formatTime(tr.NgayDang) %></span> thuộc <%= tr.TheLoai.TenTheLoai %>
								<% }); } %>
							</div>
						</div>
					</aside>
				</div>
			</div>
		</div>
	</main>
	<div class="site-newsletter py-5"
		style="background: url('/images/instagram/anhbia.jpg') center/cover no-repeat;">

		<!-- lớp phủ tối -->
		<div style="background: rgba(0,0,0,0.55); padding:50px 0;">

			<div class="container">
				<div class="text-center text-white">

					<h3 class="h3 fw-bold mb-3">
						📩 Đăng ký nhận truyện mới
					</h3>

					<p class="mb-4" style="opacity:0.9;">
						Nhận thông báo ngay khi có chương mới và truyện hot 🔥
					</p>

					<div class="row">
						<div class="col-sm-10 col-md-8 col-lg-6 mx-auto">

							<div class="input-group shadow"
								style="border-radius:50px; overflow:hidden;">

								<input type="text"
									class="form-control border-0 px-4"
									placeholder="Nhập email của bạn..."
									style="height:50px;">

								<button class="btn fw-bold text-white px-4"
										style="background:#ff6b6b;"
										onmouseover="this.style.background='#ff4b4b'"
										onmouseout="this.style.background='#ff6b6b'">
									Đăng ký
								</button>

							</div>

						</div>
					</div>

				</div>
			</div>

		</div>
	</div>
	<div class="site-instagram">
		<div class="action">
			<a class="btn btn-light" href="#">
				Theo dõi chúng tôi @ Instagram
			</a>
		</div>
		<div class="row g-0">
			<div class="col-sm-6">
				<div class="row g-0">
					<div class="col-3"><a class="photo" href="#"><img class="img-fluid" src="https://webdoctruyen-67po.onrender.com/images/instagram/1.jpg" alt="" /></a></div>
					<div class="col-3"><a class="photo" href="#"><img class="img-fluid" src="https://webdoctruyen-67po.onrender.com/images/instagram/2.jpg" alt="" /></a></div>
					<div class="col-3"><a class="photo" href="#"><img class="img-fluid" src="https://webdoctruyen-67po.onrender.com/images/instagram/3.jpg" alt="" /></a></div>
					<div class="col-3"><a class="photo" href="#"><img class="img-fluid" src="https://webdoctruyen-67po.onrender.com/images/instagram/4.jpg" alt="" /></a></div>
				</div>
			</div>
			<div class="col-sm-6">
				<div class="row g-0">
					<div class="col-3"><a class="photo" href="#"><img class="img-fluid" src="https://webdoctruyen-67po.onrender.com/images/instagram/5.jpg" alt="" /></a></div>
					<div class="col-3"><a class="photo" href="#"><img class="img-fluid" src="https://webdoctruyen-67po.onrender.com/images/instagram/6.jpg" alt="" /></a></div>
					<div class="col-3"><a class="photo" href="#"><img class="img-fluid" src="https://webdoctruyen-67po.onrender.com/images/instagram/7.jpg" alt="" /></a></div>
					<div class="col-3"><a class="photo" href="#"><img class="img-fluid" src="https://webdoctruyen-67po.onrender.com/images/instagram/8.jpg" alt="" /></a></div>
				</div>
			</div>
		</div>
	</div>
	<footer class="site-footer bg-dark">
		<div class="container">
			<ul class="nav justify-content-center">
				<li class="nav-item"><a class="nav-link" href="#">Chính sách riêng tư</a></li>
				<li class="nav-item"><a class="nav-link" href="/dangky">Đăng ký</a></li>
				<li class="nav-item"><a class="nav-link" href="/dangnhap">Đăng nhập</a></li>
				<li class="nav-item"><a class="nav-link" href="#">Liên hệ</a></li>
			</ul>
			<div class="copy">
				Bản quyền &copy; 2025 bởi Lê Nhựt Hào - Nguyễn Chí Thanh.
			</div>
		</div>
	</footer>
	<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

	<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

	<script src="https://webdoctruyen-67po.onrender.com/js/app.js"></script>

	<script>
	document.addEventListener('DOMContentLoaded', function() {

		// chuyen muc dropdown
		var dropdownElement = document.getElementById('chuyenmuc');
		if (dropdownElement) {
			dropdownElement.addEventListener('click', function (e) {
				e.preventDefault();
				var menu = this.nextElementSibling;
				if (menu) {
					menu.classList.toggle('show');
				}
			});
		}

		// user dropdown
		const userBtn = document.getElementById('userMenu');
		const userMenu = document.getElementById('userDropdown');

		if (userBtn) {
			userBtn.addEventListener('click', function (e) {
				e.preventDefault();

				if (userMenu.style.visibility === 'visible') {
					userMenu.style.visibility = 'hidden';
					userMenu.style.opacity = '0';
				} else {
					userMenu.style.visibility = 'visible';
					userMenu.style.opacity = '1';
				}
			});
		}

		// Đóng dropdown khi click ra ngoài
		document.addEventListener('click', function (e) {

			// đóng chuyên mục
			if (dropdownElement && !dropdownElement.contains(e.target)) {
				var menu = dropdownElement.nextElementSibling;
				if (menu) menu.classList.remove('show');
			}

			// đóng user
			if (userBtn && !userBtn.contains(e.target) && !userMenu.contains(e.target)) {
				userMenu.style.visibility = 'hidden';
				userMenu.style.opacity = '0';
			}
		});

	});
	</script>
	<style>

	/* đảm bảo navbar không chặn dropdown */
	.navbar {
		overflow: visible;
	}

	/* custom user dropdown */
	#userDropdown {
		position: absolute;
		right: 0;
		top: 100%;
		min-width: 180px;
		max-width: 90vw;
		z-index: 9999;
	}

	/* mobile fix */
	@media (max-width: 768px) {
		#userDropdown {
			position: static;
			width: 100%;
		}

		.dropdown-menu {
			position: static;
			width: 100%;
			max-width: 100%;
			box-shadow: none;
		}
	}
	</style>
</body>
</html>