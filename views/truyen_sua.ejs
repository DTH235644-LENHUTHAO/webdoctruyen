<!DOCTYPE html>
<html lang="en">

<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1" />
	<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
	<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
	<title><%= title %> - Web Truyện</title>
</head>

<body>
	<div class="container">
		<!-- Menu ngang -->
		<%- include('navbar') %>
		
		<!-- Nội dung chính -->
		<div class="card mt-3">
			<div class="card-header"><%= title %></div>
			<div class="card-body">
				<form action="/truyen/sua/<%= truyen._id %>" method="post" class="needs-validation" novalidate enctype="multipart/form-data">
					<div class="mb-3">
						<label for="MaTheLoai" class="form-label">Thể loại</label>
						<select class="form-select" id="MaTheLoai" name="MaTheLoai" required>
							<option value="">-- Chọn --</option>
							<% theloai.forEach(tl => { %>
								<% if(tl._id == truyen.TheLoai.valueOf()) { %>
									<option value="<%= tl._id %>" selected><%= tl.TenTheLoai %></option>
								<% } else { %>
									<option value="<%= tl._id %>"><%= tl.TenTheLoai %></option>
								<% } %>
							<% }); %>
						</select>
					</div>
					
					<div class="mb-3">
						<label for="TenTruyen" class="form-label">Tên truyện</label>
						<input type="text" class="form-control" id="TenTruyen" name="TenTruyen" value="<%= truyen.TenTruyen %>" required />
					</div>
					
					<div class="mb-3">
						<label for="TomTat" class="form-label">Tóm tắt truyện</label>
						<textarea class="form-control" id="TomTat" name="TomTat" required><%= truyen.TomTat %></textarea>
					</div>
					
					<div class="mb-3">
						<label for="TacGia" class="form-label">Tác giả</label>
						<input type="text" class="form-control" id="TacGia" name="TacGia" value="<%= truyen.TacGia %>" required />
					</div>
					
					<div class="mb-3">
						<label for="HinhAnh" class="form-label">Hình ảnh</label>
						<input type="file" class="form-control" id="HinhAnh" name="HinhAnh" accept="image/*" />
						
						<!-- preview -->
						<img id="preview" src="<%= truyen.HinhAnh %>" class="mt-2" style="max-width:200px;">
					</div>
					
					<button type="submit" class="btn btn-primary"><i class="bi bi-cloud-arrow-up"></i> Cập nhật bài viết</button>
				</form>
			</div>
		</div>
		
		<!-- Footer -->
		<%- include('footer') %>
	</div>
	
	<%- include('javascript') %>
	<script src="https://cdn.ckeditor.com/4.22.1/full/ckeditor.js"></script>
	<script>
		CKEDITOR.replace('NoiDung', {
			customConfig: 'https://webdoctruyen-67po.onrender.com/js/config.js'
		});
	</script>
	<script>
		document.getElementById('HinhAnh').addEventListener('change', function () {
			const file = this.files[0];
			if (file) {
				document.getElementById('preview').src = URL.createObjectURL(file);
			}
		});
	</script>
</body>

</html>