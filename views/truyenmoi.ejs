<!DOCTYPE html>
<html lang="en">

<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1" />
	<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
	<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
	<title><%= title %> - Web Truyện</title>
</head>

<body>
	<div class="container">

		<!-- Navbar (GIỮ NGUYÊN) -->
		<%- include('navbar') %>

		<!-- Nội dung -->
		<div class="card mt-3">
			<div class="card-header fw-bold"><%= title %></div>

			<div class="card-body">
				<div class="row">

					<% truyen.forEach(t => { %>
						<div class="col-md-3 mb-3">
							<a href="/truyen/chitiet/<%= t._id %>" style="text-decoration:none;color:inherit;">
								
								<div class="card h-100 shadow-sm"
									style="transition:0.3s;cursor:pointer;"
									onmouseover="this.style.transform='scale(1.05)'"
									onmouseout="this.style.transform='scale(1)'">

									<!-- Ảnh -->
									<img src="<%= t.HinhAnh || '/images/noimage.png' %>"
										style="height:200px;object-fit:cover;">

									<!-- Nội dung -->
									<div class="card-body">
										<h6 class="card-title">
											<%= t.TenTruyen %>
										</h6>
									</div>

									<!-- Footer -->
									<div class="card-footer text-muted small">
										<i class="bi bi-clock"></i>
										<%= new Date(t.NgayDang).toLocaleDateString('vi-VN') %>
									</div>

								</div>

							</a>
						</div>
					<% }) %>

				</div>
			</div>
		</div>

		<!-- Footer -->
		<%- include('footer') %>

	</div>

	<%- include('javascript') %>
</body>

</html>